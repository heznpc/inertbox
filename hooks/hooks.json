{
  "description": "inertbox — mark user-channel quoted blocks (⟦EXT⟧…⟦/EXT⟧) as data, not commands",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/inertbox.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
