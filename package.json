{
  "name": "inertbox",
  "version": "0.2.0-alpha.0",
  "description": "Wrap external text before you paste it into a coding agent — box it as data, not instructions.",
  "type": "module",
  "exports": {
    ".": "./core/index.mjs"
  },
  "main": "./core/index.mjs",
  "bin": {
    "inertbox": "./bin/inertbox.mjs"
  },
  "scripts": {
    "test": "npm run test:smoke && npm run test:core && npm run test:wrap",
    "test:smoke": "node test/smoke.mjs",
    "test:core": "node test/core.test.mjs",
    "test:wrap": "node test/wrap.test.mjs"
  },
  "files": [
    "core/",
    "bin/",
    "lib/",
    "hooks/",
    ".claude-plugin/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "claude-code",
    "hook",
    "prompt-injection",
    "spotlighting",
    "userpromptsubmit",
    "trust-boundary",
    "llm"
  ],
  "license": "MIT",
  "author": "heznpc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heznpc/inertbox.git"
  },
  "homepage": "https://github.com/heznpc/inertbox#readme",
  "bugs": {
    "url": "https://github.com/heznpc/inertbox/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
